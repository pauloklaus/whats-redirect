{
  "name": "whatsredirect",
  "version": "0.3.2",
  "description": "Open-source WhatsApp redirect PWA built with Vue 3",
  "type": "module",
  "license": "MIT",
  "author": "Paulo Sergio Klaus (https://github.com/pauloklaus)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pauloklaus/whats-redirect.git"
  },
  "bugs": {
    "url": "https://github.com/pauloklaus/whats-redirect/issues"
  },
  "homepage": "https://whats.pauloklaus.com.br",
  "keywords": [
    "vue",
    "vue3",
    "vite",
    "pwa",
    "whatsapp",
    "redirect"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.9",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^17.4.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.5.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "sharp": "^0.33.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.46.4",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.0.9",
    "vue-tsc": "^2.2.8"
  }
}
